---
# Clang-tidy checks for the C++ bridge layer (src/cpp/).
#
# Enabled families: bugprone, performance, readability, modernize, misc, cert,
# and the built-in clang-analyzer. Disabled checks below are either false
# positives for this codebase, style preferences we've settled on, or duplicate
# of a more specific check.
Checks: >
  -*,
  bugprone-*,
  performance-*,
  readability-*,
  modernize-*,
  misc-*,
  cert-*,
  clang-analyzer-*,
  -bugprone-unchecked-optional-access,
  -bugprone-easily-swappable-parameters,
  -bugprone-implicit-widening-of-multiplication-result,
  -cert-err58-cpp,
  -misc-non-private-member-variables-in-classes,
  -misc-include-cleaner,
  -misc-use-anonymous-namespace,
  -misc-no-recursion,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-avoid-c-arrays,
  -performance-enum-size,
  -performance-no-int-to-ptr,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-implicit-bool-conversion,
  -readability-braces-around-statements,
  -readability-function-cognitive-complexity,
  -readability-named-parameter,
  -readability-isolate-declaration,
  -readability-uppercase-literal-suffix,
  -readability-static-definition-in-anonymous-namespace,
  -readability-convert-member-functions-to-static,
WarningsAsErrors: ''
HeaderFilterRegex: 'src/cpp/.*\.(h|cpp)$'
FormatStyle: file

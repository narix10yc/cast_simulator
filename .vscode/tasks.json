{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "clangd: generate compile_commands",
      "type": "shell",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/generate_clangd_compile_commands.py",
        "--output",
        "${workspaceFolder}/.vscode/compile_commands.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
